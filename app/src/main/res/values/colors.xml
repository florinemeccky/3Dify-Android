<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        3DIFY PRECISION DARK — Design System v2
        ════════════════════════════════════════
        Rule: Orange is used ONLY for:
          - Active nav tab underline
          - Primary CTA button fill
          - Progress bar fills
          - Focused input border
          - Selected category highlight
          - Achievement unlocked ring

        Everything else is grayscale.
    -->

    <!-- ── Backgrounds ── -->
    <color name="bg_primary">#0C0C0C</color>
    <color name="bg_surface_1">#141414</color>
    <color name="bg_surface_2">#1C1C1C</color>
    <color name="bg_surface_3">#242424</color>
    <color name="bg_overlay">#99000000</color>

    <!-- ── Borders / Dividers ── -->
    <color name="border_subtle">#1E1E1E</color>
    <color name="border_default">#2A2A2A</color>
    <color name="border_strong">#3A3A3A</color>

    <!-- ── Text ── -->
    <color name="text_1">#EDEDED</color>
    <color name="text_2">#9A9A9A</color>
    <color name="text_3">#555555</color>
    <color name="text_inverse">#0C0C0C</color>

    <!-- ── Orange Accent (use sparingly) ── -->
    <color name="orange">#FF6A00</color>
    <color name="orange_10">#1AFF6A00</color>
    <color name="orange_15">#26FF6A00</color>
    <color name="orange_20">#33FF6A00</color>
    <color name="orange_glow">#FF8C3A</color>

    <!-- ── Semantic ── -->
    <color name="success">#34D399</color>
    <color name="success_10">#1A34D399</color>
    <color name="warning">#FBBF24</color>
    <color name="warning_10">#1AFBBF24</color>
    <color name="error">#F87171</color>
    <color name="error_10">#1AF87171</color>
    <color name="info">#60A5FA</color>
    <color name="info_10">#1A60A5FA</color>

    <!-- ── Difficulty Badge Colors ── -->
    <color name="diff_beginner">#34D399</color>
    <color name="diff_beginner_bg">#1234D399</color>
    <color name="diff_intermediate">#FBBF24</color>
    <color name="diff_intermediate_bg">#12FBBF24</color>
    <color name="diff_advanced">#F87171</color>
    <color name="diff_advanced_bg">#12F87171</color>

    <!-- ── Category Accent Colors ── -->
    <color name="cat_basics">#60A5FA</color>
    <color name="cat_modeling">#FF6A00</color>
    <color name="cat_animation">#A78BFA</color>
    <color name="cat_sculpting">#34D399</color>
    <color name="cat_rendering">#FBBF24</color>
    <color name="cat_nodes">#F87171</color>
    <color name="cat_materials">#F472B6</color>

    <!-- ── Light mode overrides (in values/colors_semantic.xml) ── -->

    <!-- ── Compatibility (Legacy Color Names) ── -->
    <color name="orange_dim">@color/orange_10</color>
    <color name="orange_border">@color/orange</color>
    <color name="orange_mid">@color/orange</color>
    <color name="orange_neon">@color/orange_glow</color>
    <color name="red_dim">@color/error_10</color>
    <color name="black_card">@color/bg_surface_1</color>
    <color name="black_card2">@color/bg_surface_2</color>
    <color name="black_primary">@color/bg_primary</color>
    <color name="black_surface">@color/bg_surface_1</color>
    <color name="border_dark">@color/border_strong</color>
    <color name="border_mid">@color/border_default</color>
    <color name="blue_dim">@color/info_10</color>
    <color name="green_dim">@color/success_10</color>
    <color name="white_primary">@color/text_1</color>
    <color name="gray_text">@color/text_2</color>
    <color name="color_purple">@color/cat_animation</color>

</resources>

<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        3DIFY PRECISION DARK
        Base theme — all activities inherit this.
        AppCompatDelegate controls night/day mode switching.
    -->
    <style name="Theme.3Dify" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Brand -->
        <item name="colorPrimary">@color/orange</item>
        <item name="colorPrimaryVariant">@color/orange_glow</item>
        <item name="colorOnPrimary">@color/text_inverse</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/cat_basics</item>
        <item name="colorOnSecondary">@color/text_inverse</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface_1</item>
        <item name="colorOnSurface">@color/text_1</item>
        <item name="colorOnBackground">@color/text_1</item>

        <!-- Status bar — dark, no light icons -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/bg_surface_1</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">@color/orange_10</item>

        <!-- Cards -->
        <item name="materialCardViewStyle">@style/Widget.3Dify.Card</item>

        <!-- Text inputs -->
        <item name="textInputStyle">@style/Widget.3Dify.TextInput</item>

        <!-- Screen transition -->
        <item name="android:windowAnimationStyle">@style/Transition.3Dify</item>

    </style>

    <!-- Splash — fullscreen, no status bar -->
    <style name="Theme.3Dify.Splash" parent="Theme.3Dify">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <!-- ══ COMPONENT STYLES ══ -->

    <style name="Widget.3Dify" parent="" />

    <!-- Card — flat, border, no shadow -->
    <style name="Widget.3Dify.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_surface_1</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_default</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/orange_10</item>
    </style>

    <!-- Text input — filled, rounded -->
    <style name="Widget.3Dify.TextInput"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_surface_2</item>
        <item name="boxStrokeColor">@color/border_default</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="hintTextColor">@color/text_3</item>
        <item name="android:textColorHint">@color/text_3</item>
    </style>

    <!--
        Screen transition animation.
        Open:  new screen slides in from right, current slides out left.
        Close: current screen slides out right, previous slides in from left.
        The close animations are deliberately short (180ms vs 260ms open)
        so pressing Back feels snappy and natural rather than sluggish.
    -->
    <style name="Transition.3Dify" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left_close</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right_close</item>
    </style>

    <!-- ══ TEXT APPEARANCE STYLES ══ -->

    <style name="TextAppearance.3Dify" parent="TextAppearance.MaterialComponents.Body1" />

    <style name="TextAppearance.3Dify.Display">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/text_1</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <style name="TextAppearance.3Dify.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/text_1</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.3Dify.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_2</item>
        <item name="android:lineSpacingMultiplier">1.6</item>
    </style>

    <style name="TextAppearance.3Dify.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_3</item>
    </style>

    <style name="TextAppearance.3Dify.SectionLabel">
        <item name="android:textSize">@dimen/section_label_size</item>
        <item name="android:textColor">@color/text_3</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- ══ BUTTON STYLES ══ -->

    <style name="Widget.3Dify.Button.Primary"
        parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/orange</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_body_lg</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/btn_height_primary</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="rippleColor">@color/orange_20</item>
    </style>

    <style name="Widget.3Dify.Button.Secondary"
        parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border_default</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_2</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:minHeight">@dimen/btn_height_secondary</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="Widget.3Dify.NavIndicator">
        <item name="android:color">@color/orange_10</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Pill</item>
    </style>

    <style name="ShapeAppearance.Pill"
        parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>

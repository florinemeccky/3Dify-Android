<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base theme — uses DayNight so Android automatically switches
        between night (dark) and day (light) variants.
        AppCompatDelegate controls which mode is active.
    -->
    <style name="Theme.3Dify" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FF6A00</item>
        <item name="colorPrimaryVariant">#FF8C00</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSecondary">#4A90E2</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSurface">?attr/colorSurface</item>
        <item name="colorOnSurface">?attr/colorOnSurface</item>
        <item name="android:statusBarColor">#FF6A00</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorControlHighlight">#1AFF6A00</item>
        <item name="android:windowAnimationStyle">@style/SlideAnimation</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.3Dify.Splash" parent="Theme.3Dify">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>

    <!-- Screen slide animation -->
    <style name="SlideAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

</resources>
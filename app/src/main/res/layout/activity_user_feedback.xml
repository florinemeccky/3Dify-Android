<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background_primary" android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView android:id="@+id/tv_back"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← Back" android:textColor="#FF6A00" android:textSize="14sp"
            android:clickable="true" android:focusable="true" android:padding="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Orange accent bar — small visual detail that adds personality -->
        <View android:id="@+id/view_accent"
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:background="#FF6A00"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_back"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView android:id="@+id/tv_title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:text="Give Feedback."
            android:textColor="@color/text_primary" android:textSize="26sp" android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/view_accent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Help us improve 3Dify. Your feedback matters."
            android:textColor="@color/text_muted" android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Star rating label -->
        <TextView android:id="@+id/lbl_rating"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="28dp" android:text="Rate your experience"
            android:textColor="#AAAAAA" android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Star rating bar -->
        <RatingBar android:id="@+id/rating_bar"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:numStars="5" android:stepSize="1" android:rating="5"
            android:progressTint="#FF6A00"
            app:layout_constraintTop_toBottomOf="@id/lbl_rating"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Feedback text label -->
        <TextView android:id="@+id/lbl_feedback"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" android:text="Your feedback"
            android:textColor="#AAAAAA" android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/rating_bar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Multi-line feedback input -->
        <EditText android:id="@+id/et_feedback"
            android:layout_width="0dp" android:layout_height="120dp"
            android:layout_marginTop="8dp" android:background="@color/background_card"
            android:hint="Tell us what you think about 3Dify…"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:textSize="14sp" android:padding="14dp"
            android:gravity="top" android:inputType="textMultiLine"
            android:imeOptions="actionDone"
            app:layout_constraintTop_toBottomOf="@id/lbl_feedback"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button android:id="@+id/btn_submit"
            android:layout_width="0dp" android:layout_height="52dp"
            android:layout_marginTop="20dp" android:text="Submit Feedback"
            android:textColor="#000000" android:textStyle="bold" android:textSize="15sp"
            android:backgroundTint="#FF6A00"
            app:layout_constraintTop_toBottomOf="@id/et_feedback"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView android:id="@+id/tv_success"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="✅ Thank you! Your feedback has been saved."
            android:textColor="#2ECC71" android:textSize="14sp"
            android:gravity="center" android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btn_submit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
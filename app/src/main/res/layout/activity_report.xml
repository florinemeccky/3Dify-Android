<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:id="@+id/tv_back"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← Back" android:textColor="#FF6A00" android:textSize="14sp"
            android:clickable="true" android:focusable="true"
            android:padding="4dp" android:layout_marginBottom="20dp"/>

        <!-- Orange accent bar — small visual detail that adds personality -->
        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:background="#FF6A00"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="My Reports." android:textColor="@color/text_primary"
            android:textSize="26sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="A summary of your learning activity."
            android:textColor="@color/text_muted" android:textSize="14sp" android:layout_marginBottom="28dp"/>

        <!-- Report card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/background_card" android:orientation="vertical"
            android:padding="20dp" android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="LEARNING SUMMARY"
                android:textColor="#555555" android:textSize="11sp"
                android:letterSpacing="0.12" android:layout_marginBottom="16dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Tutorials Completed"
                    android:textColor="#AAAAAA" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_report_completed"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#FF6A00" android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Feedback Submitted"
                    android:textColor="#AAAAAA" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_report_feedback"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#FF6A00" android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Complaints Submitted"
                    android:textColor="#AAAAAA" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_report_complaints"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="#FF6A00" android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Generate report button -->
        <Button android:id="@+id/btn_generate"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Generate Full Report"
            android:textColor="#000000" android:textStyle="bold" android:textSize="15sp"
            android:backgroundTint="#FF6A00" android:layout_marginBottom="16dp"/>

        <!-- Report output area -->
        <TextView android:id="@+id/tv_report_output"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/background_card" android:padding="16dp"
            android:textColor="#AAAAAA" android:textSize="13sp"
            android:lineSpacingMultiplier="1.6"
            android:visibility="gone"
            android:layout_marginBottom="24dp"/>

        <!-- History Title -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="HISTORY"
            android:textColor="#555555" android:textSize="11sp"
            android:letterSpacing="0.12" android:layout_marginBottom="16dp"/>

        <!-- History container where SQLite reports are loaded -->
        <LinearLayout android:id="@+id/ll_report_history"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!--
    item_category_row.xml
    A full-width category row for the Explore screen.
    Shows icon, name, tutorial count, difficulty badge, and arrow.
    The icon background and badge color are set in Java per category.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:background="@color/background_card"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon container -->
    <LinearLayout
        android:id="@+id/ll_cat_icon_bg"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:gravity="center"
        android:layout_marginEnd="14dp"
        android:background="#1AFF6A00">

        <TextView
            android:id="@+id/tv_cat_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔷"
            android:textSize="22sp"/>
    </LinearLayout>

    <!-- Name and count column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_cat_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3D Modeling"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_cat_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="38 tutorials"
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Difficulty badge -->
    <TextView
        android:id="@+id/tv_cat_difficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="All levels"
        android:textColor="#FF6A00"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="#1AFF6A00"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"/>

    <!-- Arrow -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textColor="#555555"
        android:textSize="22sp"/>

</LinearLayout>
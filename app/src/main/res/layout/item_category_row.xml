<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:background="@drawable/bg_ripple_row"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon container -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="16dp">

        <View
            android:id="@+id/view_cat_icon_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_surface_2"/>

        <ImageView
            android:id="@+id/iv_cat_row_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"/>
    </FrameLayout>

    <!-- Name + count -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_cat_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3D Modeling"
            android:textColor="@color/text_1"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:layout_marginBottom="3dp"/>

        <TextView
            android:id="@+id/tv_cat_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="38 tutorials"
            android:textColor="@color/text_3"
            android:textSize="@dimen/text_caption"/>
    </LinearLayout>

    <!-- Difficulty pill -->
    <TextView
        android:id="@+id/tv_cat_difficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="All levels"
        android:textSize="@dimen/text_label"
        android:textStyle="bold"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:background="@drawable/bg_pill"/>

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_arrow_right"
        android:scaleType="fitCenter"/>

</LinearLayout>

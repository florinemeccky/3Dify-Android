<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0A0A0A" android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:id="@+id/tv_back"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← Back" android:textColor="#FF6A00" android:textSize="14sp"
            android:clickable="true" android:focusable="true"
            android:padding="4dp" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Contact Us." android:textColor="#FFFFFF"
            android:textSize="26sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Reach our support team directly."
            android:textColor="#888888" android:textSize="14sp" android:layout_marginBottom="32dp"/>

        <!-- Phone call button -->
        <LinearLayout android:id="@+id/btn_call"
            android:layout_width="match_parent" android:layout_height="64dp"
            android:background="#111111" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="20dp"
            android:paddingEnd="20dp" android:layout_marginBottom="12dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📞  Call Support"
                android:textColor="#E0E0E0" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="+255 614 886 685"
                android:textColor="#FF6A00" android:textSize="13sp"/>
        </LinearLayout>

        <!-- SMS button -->
        <LinearLayout android:id="@+id/btn_sms"
            android:layout_width="match_parent" android:layout_height="64dp"
            android:background="#111111" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="20dp"
            android:paddingEnd="20dp" android:layout_marginBottom="12dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💬  Send SMS"
                android:textColor="#E0E0E0" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="+255 614 886 685"
                android:textColor="#FF6A00" android:textSize="13sp"/>
        </LinearLayout>

        <!-- Email button -->
        <LinearLayout android:id="@+id/btn_email"
            android:layout_width="match_parent" android:layout_height="64dp"
            android:background="#111111" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="20dp"
            android:paddingEnd="20dp" android:layout_marginBottom="28dp"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📧  Email Support"
                android:textColor="#E0E0E0" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="florinemeccky@gmail.com"
                android:textColor="#FF6A00" android:textSize="13sp"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Support hours: Monday – Friday, 8am – 5pm EAT"
            android:textColor="#555555" android:textSize="12sp" android:gravity="center"
            android:layout_gravity="center"/>

    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Progress."
                android:textColor="@color/text_1"
                android:textSize="@dimen/text_display"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- ══ STAT CARDS ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin"
            android:layout_marginBottom="28dp">

            <!-- Completed -->
            <LinearLayout
                android:id="@+id/card_completed"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_completed_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/orange"
                    android:textSize="36sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed"
                    android:textColor="@color/text_3"
                    android:textSize="@dimen/text_caption"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Streak -->
            <LinearLayout
                android:id="@+id/card_streak"
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_streak_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/error"
                    android:textSize="36sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day Streak"
                    android:textColor="@color/text_3"
                    android:textSize="@dimen/text_caption"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ══ SKILLS PROGRESS ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginBottom="12dp"
            android:text="Skills"
            style="@style/TextAppearance.3Dify.SectionLabel"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginEnd="@dimen/screen_margin"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bg_surface_1"
            android:orientation="vertical"
            android:padding="@dimen/space_20">

            <!-- Modeling -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:layout_marginBottom="18dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Modeling"
                        android:textColor="@color/text_1" android:textSize="@dimen/text_body"
                        android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_skill_modeling_pct"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0%" android:textColor="@color/orange"
                        android:textSize="@dimen/text_body" android:textStyle="bold"/>
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_bar_height"
                    android:background="@color/border_default">
                    <View android:id="@+id/bar_modeling" android:layout_width="0dp"
                        android:layout_height="match_parent" android:background="@color/orange"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Animation -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:layout_marginBottom="18dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Animation"
                        android:textColor="@color/text_1" android:textSize="@dimen/text_body"
                        android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_skill_animation_pct"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0%" android:textColor="@color/cat_animation"
                        android:textSize="@dimen/text_body" android:textStyle="bold"/>
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_bar_height"
                    android:background="@color/border_default">
                    <View android:id="@+id/bar_animation" android:layout_width="0dp"
                        android:layout_height="match_parent" android:background="@color/cat_animation"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Sculpting -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:layout_marginBottom="18dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Sculpting"
                        android:textColor="@color/text_1" android:textSize="@dimen/text_body"
                        android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_skill_sculpting_pct"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0%" android:textColor="@color/cat_sculpting"
                        android:textSize="@dimen/text_body" android:textStyle="bold"/>
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_bar_height"
                    android:background="@color/border_default">
                    <View android:id="@+id/bar_sculpting" android:layout_width="0dp"
                        android:layout_height="match_parent" android:background="@color/cat_sculpting"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Rendering -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Rendering"
                        android:textColor="@color/text_1" android:textSize="@dimen/text_body"
                        android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_skill_rendering_pct"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0%" android:textColor="@color/cat_rendering"
                        android:textSize="@dimen/text_body" android:textStyle="bold"/>
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_bar_height"
                    android:background="@color/border_default">
                    <View android:id="@+id/bar_rendering" android:layout_width="0dp"
                        android:layout_height="match_parent" android:background="@color/cat_rendering"/>
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ══ ACHIEVEMENTS ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginBottom="12dp"
            android:text="Achievements"
            style="@style/TextAppearance.3Dify.SectionLabel"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin">

            <!-- Row 1 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- First Tutorial — unlocked -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_achievement_unlocked"
                    android:orientation="vertical" android:gravity="center"
                    android:paddingTop="20dp" android:paddingBottom="20dp"
                    android:paddingStart="12dp" android:paddingEnd="12dp">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp"
                        android:src="@drawable/ic_school" android:alpha="0.9"
                        android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="First Lesson" android:textColor="@color/text_1"
                        android:textSize="@dimen/text_body_sm" android:textStyle="bold"
                        android:gravity="center" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Completed" android:textColor="@color/orange"
                        android:textSize="@dimen/text_label" android:gravity="center"/>
                </LinearLayout>

                <!-- 7 Day Streak — unlocked -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    android:background="@drawable/bg_achievement_unlocked"
                    android:orientation="vertical" android:gravity="center"
                    android:paddingTop="20dp" android:paddingBottom="20dp"
                    android:paddingStart="12dp" android:paddingEnd="12dp">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp"
                        android:src="@drawable/ic_nav_progress" android:alpha="0.9"
                        android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="7 Day Streak" android:textColor="@color/text_1"
                        android:textSize="@dimen/text_body_sm" android:textStyle="bold"
                        android:gravity="center" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Keep going!" android:textColor="@color/orange"
                        android:textSize="@dimen/text_label" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Modeler — locked -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_achievement_locked"
                    android:orientation="vertical" android:gravity="center"
                    android:paddingTop="20dp" android:paddingBottom="20dp"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:alpha="0.4">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp"
                        android:src="@drawable/ic_cube"
                        android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Modeler" android:textColor="@color/text_2"
                        android:textSize="@dimen/text_body_sm" android:textStyle="bold"
                        android:gravity="center" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Locked" android:textColor="@color/text_3"
                        android:textSize="@dimen/text_label" android:gravity="center"/>
                </LinearLayout>

                <!-- Artist — locked -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    android:background="@drawable/bg_achievement_locked"
                    android:orientation="vertical" android:gravity="center"
                    android:paddingTop="20dp" android:paddingBottom="20dp"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:alpha="0.4">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp"
                        android:src="@drawable/ic_palette"
                        android:layout_marginBottom="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Artist" android:textColor="@color/text_2"
                        android:textSize="@dimen/text_body_sm" android:textStyle="bold"
                        android:gravity="center" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Locked" android:textColor="@color/text_3"
                        android:textSize="@dimen/text_label" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_progress.xml
    Required IDs for ProgressFragment.java:
      - tv_completed_count  (number from SQLite)
      - tv_streak_count     (day streak number)
      - bar_modeling        (orange fill bar)
      - bar_animation       (purple fill bar)
      - bar_sculpting       (blue fill bar)
      - bar_rendering       (yellow fill bar)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Progress."
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- Stat cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <!-- Completed tutorials stat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="#111111"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_completed_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FF6A00"
                    android:textSize="36sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Day streak stat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="#111111"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_streak_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0🔥"
                    android:textColor="#E74C3C"
                    android:textSize="36sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day Streak"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Skills heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKILLS PROGRESS"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="16dp"/>

        <!-- Skills card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#111111"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="28dp">

            <!-- Modeling bar -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Modeling"
                        android:textColor="#E0E0E0" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="72%" android:textColor="#FF6A00" android:textSize="13sp"/>
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent" android:layout_height="6dp"
                    android:background="#222222">
                    <View android:id="@+id/bar_modeling" android:layout_width="0dp"
                        android:layout_height="6dp" android:background="#FF6A00"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Animation bar -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Animation"
                        android:textColor="#E0E0E0" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="38%" android:textColor="#7B5EA7" android:textSize="13sp"/>
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent" android:layout_height="6dp"
                    android:background="#222222">
                    <View android:id="@+id/bar_animation" android:layout_width="0dp"
                        android:layout_height="6dp" android:background="#7B5EA7"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Sculpting bar -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Sculpting"
                        android:textColor="#E0E0E0" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="55%" android:textColor="#4A90E2" android:textSize="13sp"/>
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent" android:layout_height="6dp"
                    android:background="#222222">
                    <View android:id="@+id/bar_sculpting" android:layout_width="0dp"
                        android:layout_height="6dp" android:background="#4A90E2"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Rendering bar -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Rendering"
                        android:textColor="#E0E0E0" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="20%" android:textColor="#F4D03F" android:textSize="13sp"/>
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent" android:layout_height="6dp"
                    android:background="#222222">
                    <View android:id="@+id/bar_rendering" android:layout_width="0dp"
                        android:layout_height="6dp" android:background="#F4D03F"/>
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Achievements heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACHIEVEMENTS"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="16dp"/>

        <!-- Achievement badges grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="8dp"
                android:background="#1AFF6A00"
                android:orientation="vertical" android:gravity="center" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏆" android:textSize="28sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="First Tutorial" android:textColor="#888888"
                    android:textSize="11sp" android:gravity="center" android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="8dp"
                android:background="#1AFF6A00"
                android:orientation="vertical" android:gravity="center" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔥" android:textSize="28sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="7 Day Streak" android:textColor="#888888"
                    android:textSize="11sp" android:gravity="center" android:layout_marginTop="6dp"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!--
    item_category_pill.xml
    A small pill chip for the horizontal category row on the Home screen.
    The icon background color is set programmatically in the adapter
    using the category's colorHex value.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_marginEnd="10dp"
    android:padding="12dp"
    android:minWidth="68dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon container — background color set in Java per category -->
    <LinearLayout
        android:id="@+id/ll_icon_bg"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:layout_marginBottom="6dp"
        android:background="#1AFF6A00">

        <TextView
            android:id="@+id/tv_category_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔷"
            android:textSize="18sp"/>
    </LinearLayout>

    <!-- Category name -->
    <TextView
        android:id="@+id/tv_category_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Basics"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:gravity="center"/>

</LinearLayout>
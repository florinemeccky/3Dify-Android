<?xml version="1.0" encoding="utf-8"?>
<!--
    CATEGORY PILL — horizontal scroll in Home
    Selected state: orange border + orange label
    Default state: gray border + gray label
    Set programmatically by CategoryAdapter.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="36dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginEnd="8dp"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:background="@drawable/bg_pill"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/iv_pill_icon"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:scaleType="fitCenter"
        android:alpha="0.6"
        android:layout_marginEnd="6dp"/>

    <TextView
        android:id="@+id/tv_category_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Modeling"
        android:textColor="@color/text_3"
        android:textSize="@dimen/text_body_sm"
        android:textStyle="bold"/>

</LinearLayout>

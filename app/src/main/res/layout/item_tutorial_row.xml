<?xml version="1.0" encoding="utf-8"?>
<!--
    TUTORIAL ROW — vertical list
    Left: 72dp square gradient thumbnail with icon
    Right: category label, title, difficulty badge + duration
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:background="@drawable/bg_ripple_row"
    android:clickable="true"
    android:focusable="true">

    <!-- Thumbnail -->
    <FrameLayout
        android:layout_width="@dimen/thumb_row_size"
        android:layout_height="@dimen/thumb_row_size"
        android:layout_marginEnd="16dp">

        <View
            android:id="@+id/view_row_thumb_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_thumbnail_modeling"/>

        <ImageView
            android:id="@+id/iv_row_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:alpha="0.9"/>
    </FrameLayout>

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Category label -->
        <TextView
            android:id="@+id/tv_row_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3D Modeling"
            android:textColor="@color/orange"
            android:textSize="@dimen/text_label"
            android:textAllCaps="true"
            android:letterSpacing="0.06"
            android:layout_marginBottom="3dp"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tv_row_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Introduction to 3D Modeling"
            android:textColor="@color/text_1"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp"/>

        <!-- Bottom row: badge + dot + duration -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_row_difficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Beginner"
                android:textColor="@color/diff_beginner"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/bg_badge_beginner"
                android:layout_marginEnd="8dp"/>

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:background="@color/text_3"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_row_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="28 min"
                android:textColor="@color/text_3"
                android:textSize="@dimen/text_caption"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Arrow -->
    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="12dp"
        android:src="@drawable/ic_arrow_right"
        android:scaleType="fitCenter"/>

</LinearLayout>

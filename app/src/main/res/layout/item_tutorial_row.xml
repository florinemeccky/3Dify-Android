<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_ripple_row"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <!--
        Thumbnail: FrameLayout itself carries the background color.
        The adapter sets setBackgroundResource() on fl_row_thumbnail directly.
        This is more reliable than setting it on a child View.
    -->
    <FrameLayout
        android:id="@+id/fl_row_thumbnail"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_thumbnail_basics">

        <ImageView
            android:id="@+id/iv_row_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_school"/>
    </FrameLayout>

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_row_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:letterSpacing="0.06"
            android:text="3D Modeling"
            android:textAllCaps="true"
            android:textColor="@color/orange"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/tv_row_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Introduction to 3D Modeling"
            android:textColor="@color/text_1"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_row_difficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_badge_beginner"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Beginner"
                android:textColor="#34D399"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="3dp"
                android:layout_height="3dp"
                android:layout_marginEnd="8dp"
                android:background="@color/text_3"/>

            <TextView
                android:id="@+id/tv_row_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="28 min"
                android:textColor="@color/text_3"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="16dp"
        android:alpha="0.3"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_arrow_right"/>

</LinearLayout>
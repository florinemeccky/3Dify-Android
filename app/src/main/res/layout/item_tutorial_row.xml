<?xml version="1.0" encoding="utf-8"?>
<!--
    TUTORIAL ROW ITEM
    ══════════════════
    Used in the vertical recommended list in HomeFragment
    and also in ExploreFragment's full category list.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true">

    <!-- Thumbnail -->
    <LinearLayout
        android:id="@+id/ll_thumb_row"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_tut_thumb"
        android:gravity="center"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tv_row_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯"
            android:textSize="22sp"/>
    </LinearLayout>

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_row_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Introduction to Materials"
            android:textColor="@color/white_secondary"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_row_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="32 min  •  Intermediate"
            android:textColor="@color/gray_muted"
            android:textSize="11sp"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

    <!-- Arrow -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textColor="@color/gray_muted"
        android:textSize="20sp"
        android:layout_marginStart="8dp"/>

</LinearLayout>
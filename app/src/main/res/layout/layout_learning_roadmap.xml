<?xml version="1.0" encoding="utf-8"?>
<!--
    Learning Roadmap section.
    A vertical step-by-step path.
    Completed steps show orange filled nodes.
    Pending steps show outlined nodes.
    Connected by vertical lines.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_section_card"
    android:padding="20dp">

    <!-- Roadmap title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEARNING ROADMAP"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your path to 3D mastery"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_roadmap_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 / 10"
            android:textColor="#FF6A00"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Step rows are generated in Java to avoid repetitive XML -->
    <LinearLayout
        android:id="@+id/ll_roadmap_steps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

</LinearLayout>
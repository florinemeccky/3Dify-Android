<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:id="@+id/tv_back"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← Back" android:textColor="#FF6A00" android:textSize="14sp"
            android:clickable="true" android:focusable="true"
            android:padding="4dp" android:layout_marginBottom="20dp"/>

        <!-- Orange accent bar — small visual detail that adds personality -->
        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:background="#FF6A00"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Help &amp; Support." android:textColor="@color/text_primary"
            android:textSize="26sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Frequently asked questions about 3Dify."
            android:textColor="@color/text_muted" android:textSize="14sp" android:layout_marginBottom="28dp"/>

        <!-- FAQ items -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="How do I start a tutorial?"
            android:textColor="#FF6A00" android:textSize="15sp" android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Go to the Home tab and tap any tutorial card, or browse categories in the Explore tab. Tap Watch Tutorial to begin."
            android:textColor="#AAAAAA" android:textSize="13sp"
            android:lineSpacingMultiplier="1.5" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="How is my progress tracked?"
            android:textColor="#FF6A00" android:textSize="15sp" android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="When you tap Mark Done on a tutorial, it is saved to your device. Your Progress tab shows completed counts and skill bars."
            android:textColor="#AAAAAA" android:textSize="13sp"
            android:lineSpacingMultiplier="1.5" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="How do I reset my password?"
            android:textColor="#FF6A00" android:textSize="15sp" android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="On the Login screen tap Forgot password. Enter your email and Firebase will send a reset link to your inbox within a few minutes."
            android:textColor="#AAAAAA" android:textSize="13sp"
            android:lineSpacingMultiplier="1.5" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Can I use the app offline?"
            android:textColor="#FF6A00" android:textSize="15sp" android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Progress data and settings are stored locally on your device. An internet connection is required for login, registration, and loading online tutorial videos."
            android:textColor="#AAAAAA" android:textSize="13sp"
            android:lineSpacingMultiplier="1.5" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="How do I contact support?"
            android:textColor="#FF6A00" android:textSize="15sp" android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Go to Profile → Give Feedback to send us a message, or use Profile → Contact Us to call or email our support team directly."
            android:textColor="#AAAAAA" android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!--
    item_tutorial_card.xml
    A single tutorial card used in horizontal RecyclerViews.
    Width is fixed at 150dp so cards are consistently sized.
    Tapping the card opens TutorialDetailActivity (Phase 5).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="150dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="12dp"
    android:background="@color/background_card"
    android:padding="12dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Thumbnail area with emoji icon -->
    <LinearLayout
        android:id="@+id/ll_thumbnail"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#1AFF6A00"
        android:gravity="center"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/tv_tutorial_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯"
            android:textSize="32sp"/>
    </LinearLayout>

    <!-- Tutorial title -->
    <TextView
        android:id="@+id/tv_tutorial_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tutorial Title"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="8dp"/>

    <!-- Difficulty badge -->
    <TextView
        android:id="@+id/tv_tutorial_difficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beginner"
        android:textColor="#FF6A00"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="#1AFF6A00"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:layout_marginBottom="4dp"/>

    <!-- Duration -->
    <TextView
        android:id="@+id/tv_tutorial_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="22 min"
        android:textColor="#666666"
        android:textSize="11sp"/>

</LinearLayout>
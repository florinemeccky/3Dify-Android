<?xml version="1.0" encoding="utf-8"?>
<!--
    TUTORIAL CARD — horizontal scroll
    168dp wide. Gradient thumbnail top, content bottom.
    Difficulty badge colored by level.
    Duration chip on thumbnail.
    Ripple on press.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="168dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="14dp"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_surface_1"
    app:strokeColor="@color/border_default"
    app:strokeWidth="1dp"
    android:foreground="@drawable/bg_ripple_card"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gradient thumbnail -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_tutorial_thumb_height">

            <!-- Category gradient -->
            <View
                android:id="@+id/view_thumb_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Category vector icon — centered -->
            <ImageView
                android:id="@+id/iv_tutorial_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:alpha="0.9"/>

            <!-- Duration chip — bottom right -->
            <TextView
                android:id="@+id/tv_thumb_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:text="28 min"
                android:textColor="@color/text_1"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:background="@color/bg_overlay"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"/>
        </FrameLayout>

        <!-- Card content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_tutorial_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tutorial Title"
                android:textColor="@color/text_1"
                android:textSize="@dimen/text_body_sm"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="10dp"/>

            <!-- Difficulty badge -->
            <TextView
                android:id="@+id/tv_tutorial_difficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Beginner"
                android:textColor="@color/diff_beginner"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/bg_badge_beginner"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

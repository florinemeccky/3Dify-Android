<?xml version="1.0" encoding="utf-8"?>
<!--
    TUTORIAL CARD ITEM
    ═══════════════════
    Used in the horizontal featured/recommended RecyclerViews.
    Min-width 130dp so cards are nicely sized on all phones.
    Tapped → TutorialDetailActivity
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="130dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="12dp"
    android:padding="10dp"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true">

    <!-- Thumbnail area -->
    <LinearLayout
        android:id="@+id/ll_thumb"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@drawable/bg_tut_thumb"
        android:gravity="center"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/tv_tut_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯"
            android:textSize="28sp"/>
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tv_tut_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sculpting Basics"
        android:textColor="@color/white_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="6dp"/>

    <!-- Difficulty badge -->
    <TextView
        android:id="@+id/tv_tut_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beginner"
        android:textColor="@color/orange_neon"
        android:textSize="9sp"
        android:textStyle="bold"
        android:background="@drawable/bg_badge_orange"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"/>

</LinearLayout>
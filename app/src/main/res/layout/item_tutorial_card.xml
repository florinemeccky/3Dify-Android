<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="168dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="14dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_surface_1"
    app:strokeColor="@color/border_default"
    app:strokeWidth="1dp"
    android:foreground="@drawable/bg_ripple_card"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!--
            Thumbnail area.
            The FrameLayout itself gets its background set by the adapter.
            This guarantees the color is always visible because FrameLayout
            backgrounds are never overridden by child views.
        -->
        <FrameLayout
            android:id="@+id/fl_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="106dp"
            android:background="@drawable/bg_thumbnail_basics">

            <!-- Icon — always white, always centered -->
            <ImageView
                android:id="@+id/iv_tutorial_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_school"/>

            <!-- Duration chip — bottom right -->
            <TextView
                android:id="@+id/tv_thumb_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:background="#88000000"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="28 min"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- Card body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_tutorial_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="2"
                android:text="Tutorial Title"
                android:textColor="@color/text_1"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_tutorial_difficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_beginner"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="Beginner"
                android:textColor="#34D399"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
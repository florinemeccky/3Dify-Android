<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home.xml
    Home tab layout. Uses NestedScrollView so all sections
    scroll together. RecyclerViews inside scroll horizontally.

    Required IDs for HomeFragment.java:
      - tv_greeting_label   (time-based greeting)
      - tv_username         (user's name from SQLite)
      - view_progress_fill  (orange bar inside continue learning card)
      - rv_categories       (horizontal category pills)
      - rv_featured         (horizontal tutorial cards)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ══ HEADER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning,"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="#1AFF6A00"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="18sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SEARCH BAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="15sp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search tutorials…"
                android:textColor="@color/text_hint"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Daily motivation card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:background="#0D111111"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <!-- Orange left accent line -->
            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="#FF6A00"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tv_quote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Every expert was once a beginner. Start your lesson today."
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.5"
                android:fontFamily="sans-serif-light"/>
        </LinearLayout>

        <!-- ══ CONTINUE LEARNING LABEL ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="10dp"
            android:text="CONTINUE LEARNING"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.12"/>

        <!-- ══ CONTINUE LEARNING CARD ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="28dp"
            android:background="@color/background_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="#1AFF6A00"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧊"
                        android:textSize="22sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intro to 3D Modeling"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lesson 4 of 12"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="67%"
                    android:textColor="#FF6A00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#1AFF6A00"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"/>
            </LinearLayout>

            <!-- Progress bar track and animated fill -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:background="@color/border_color">

                <View
                    android:id="@+id/view_progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:background="#FF6A00"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ══ CATEGORIES LABEL ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="10dp"
            android:text="CATEGORIES"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.12"/>

        <!-- ══ CATEGORIES HORIZONTAL RECYCLER ══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clipToPadding="false"
            android:orientation="horizontal"/>

        <!-- ══ FEATURED TUTORIALS LABEL ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FEATURED TUTORIALS"
                android:textColor="#555555"
                android:textSize="11sp"
                android:letterSpacing="0.12"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See all →"
                android:textColor="#FF6A00"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- ══ FEATURED TUTORIALS HORIZONTAL RECYCLER ══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_featured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clipToPadding="false"
            android:orientation="horizontal"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
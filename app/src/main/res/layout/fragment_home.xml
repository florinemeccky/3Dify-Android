<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home.xml
    Home tab — dashboard with greeting, search, continue learning,
    categories, and featured tutorials.
    RecyclerViews and full data will be added in Phase 4.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header: greeting and notification bell -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning,"
                    android:textColor="#888888"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Notification bell -->
            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="#1AFF6A00"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="18sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:background="#111111"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="15sp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search tutorials…"
                android:textColor="#555555"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Continue Learning section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="10dp"
            android:text="CONTINUE LEARNING"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.12"/>

        <!-- Continue Learning card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="28dp"
            android:background="#111111"
            android:orientation="vertical"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="#1AFF6A00"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧊"
                        android:textSize="22sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intro to 3D Modeling"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lesson 4 of 12"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="67%"
                    android:textColor="#FF6A00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#1AFF6A00"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"/>
            </LinearLayout>

            <!-- Progress bar track -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:background="#222222">
                <!-- Orange fill at 67% width — set programmatically in Phase 4 -->
                <View
                    android:id="@+id/view_progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:background="#FF6A00"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Featured Tutorials label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="10dp"
            android:text="FEATURED TUTORIALS"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.12"/>

        <!-- Placeholder for tutorial cards — RecyclerView added in Phase 4 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Tutorial cards coming in Phase 4"
            android:textColor="#444444"
            android:textSize="13sp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!--
    HOME FRAGMENT
    ══════════════
    WHY: First thing users see after login. Dashboard-style layout.
    Sections: Greeting + search | Continue Learning | Categories | Featured Tutorials
    Uses NestedScrollView so everything scrolls together.
    RecyclerViews inside scroll horizontally within.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ════ HEADER: Greeting + Notification Bell ════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp">

            <!-- Left: greet text -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning,"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp"/>

                <!-- Username — set in Java, "D" tinted orange via SpannableString -->
                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="florinemeccky✦"
                    android:textColor="@color/white_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Right: notification bell -->
            <LinearLayout
                android:id="@+id/btn_notif"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_notif_btn"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="16sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ════ SEARCH BAR ════ -->
        <LinearLayout
            android:id="@+id/ll_search"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_search"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="14sp"
                android:layout_marginEnd="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search tutorials…"
                android:textColor="@color/gray_muted"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- ════ CONTINUE LEARNING ════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="10dp"
            android:text="CONTINUE LEARNING"
            android:textColor="@color/gray_muted"
            android:textSize="10sp"
            android:letterSpacing="0.15"/>

        <!-- Continue Learning Card -->
        <LinearLayout
            android:id="@+id/card_continue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_continue_card"
            android:orientation="vertical"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Row: thumbnail + text + badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <!-- Thumbnail -->
                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_tut_thumb"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧊" android:textSize="20sp"/>
                </LinearLayout>

                <!-- Title + lesson -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_continue_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Intro to Modeling"
                        android:textColor="@color/white_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_continue_lesson"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lesson 4 of 12"
                        android:textColor="@color/gray_muted"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Progress badge -->
                <TextView
                    android:id="@+id/tv_continue_pct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="67%"
                    android:textColor="@color/orange_neon"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_orange"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"/>
            </LinearLayout>

            <!-- Progress bar track -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="5dp"
                android:background="@drawable/bg_progress_track">

                <!-- Progress fill — width set in Java via layout params (67%) -->
                <View
                    android:id="@+id/view_progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:background="@drawable/bg_btn_orange"/>
            </FrameLayout>

        </LinearLayout>

        <!-- ════ CATEGORIES ════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="10dp"
            android:text="CATEGORIES"
            android:textColor="@color/gray_muted"
            android:textSize="10sp"
            android:letterSpacing="0.15"/>

        <!-- Horizontal categories recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clipToPadding="false"
            android:orientation="horizontal"/>

        <!-- ════ FEATURED TUTORIALS ════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FEATURED TUTORIALS"
                android:textColor="@color/gray_muted"
                android:textSize="10sp"
                android:letterSpacing="0.15"/>

            <TextView
                android:id="@+id/tv_see_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See all →"
                android:textColor="@color/orange_neon"
                android:textSize="11sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Horizontal tutorials recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_featured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clipToPadding="false"
            android:orientation="horizontal"/>

        <!-- ════ RECOMMENDED ════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="10dp"
            android:text="RECOMMENDED FOR YOU"
            android:textColor="@color/gray_muted"
            android:textSize="10sp"
            android:letterSpacing="0.15"/>

        <!-- Vertical recommended list recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recommended"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!--
    HOME FRAGMENT
    Precision Dark v2 — no emoji, real icons, orange only for accents.
    Layout:
      1. Hero section (greeting + motivational text + CTA)
      2. Search bar
      3. Continue Learning card
      4. Category pills (horizontal scroll)
      5. Featured tutorials (horizontal scroll)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ════════════════════════════════════
             HERO SECTION
             ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <!-- Greeting row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tv_greeting_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Good morning,"
                    android:textColor="@color/text_3"
                    android:textSize="@dimen/text_body"/>

                <!-- Notification bell -->
                <LinearLayout
                    android:id="@+id/btn_notif"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_surface_2"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_bell"
                        android:scaleType="fitCenter"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Username -->
            <TextView
                android:id="@+id/tv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Florine"
                android:textColor="@color/text_1"
                android:textSize="@dimen/text_display"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Motivational subtitle -->
            <TextView
                android:id="@+id/tv_quote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready to create something amazing today?"
                android:textColor="@color/text_2"
                android:textSize="@dimen/text_body"
                android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>

        <!-- ════════════════════════════════════
             SEARCH BAR
             ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginEnd="@dimen/screen_margin"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bg_input_default"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_nav_explore"
                android:alpha="0.4"
                android:layout_marginEnd="12dp"
                android:scaleType="fitCenter"/>

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search Blender tutorials, materials, animation…"
                android:textColor="@color/text_1"
                android:textColorHint="@color/text_3"
                android:textSize="@dimen/text_body"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- No results message -->
        <LinearLayout
            android:id="@+id/ll_no_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_empty_search"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Couldn't find anything."
                android:textColor="@color/text_2"
                android:textSize="@dimen/text_headline"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Try searching for Animation, Materials or Geometry Nodes"
                android:textColor="@color/text_3"
                android:textSize="@dimen/text_body"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>

        <!-- ════════════════════════════════════
             CONTINUE LEARNING
             ════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginBottom="12dp"
            android:text="Continue Learning"
            style="@style/TextAppearance.3Dify.SectionLabel"/>

        <LinearLayout
            android:id="@+id/card_continue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginEnd="@dimen/screen_margin"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bg_ripple_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/card_padding"
            android:clickable="true"
            android:focusable="true">

            <!-- Thumbnail -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="14dp">

                <View
                    android:id="@+id/view_continue_thumb"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_thumbnail_modeling"/>

                <ImageView
                    android:id="@+id/iv_continue_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cube"
                    android:scaleType="fitCenter"/>
            </FrameLayout>

            <!-- Text -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_continue_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Intro to 3D Modeling"
                    android:textColor="@color/text_1"
                    android:textSize="@dimen/text_body_lg"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_continue_lesson"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue where you left off"
                    android:textColor="@color/text_3"
                    android:textSize="@dimen/text_caption"
                    android:layout_marginBottom="8dp"/>

                <!-- Progress bar -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_bar_height"
                    android:background="@color/border_default">

                    <View
                        android:id="@+id/view_progress_fill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@color/orange"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Arrow -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_arrow_right"
                android:scaleType="fitCenter"/>
        </LinearLayout>

        <!-- ════════════════════════════════════
             CATEGORIES
             ════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginBottom="12dp"
            android:text="Categories"
            style="@style/TextAppearance.3Dify.SectionLabel"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin"
            android:clipToPadding="false"
            android:orientation="horizontal"/>

        <!-- ════════════════════════════════════
             FEATURED TUTORIALS
             ════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Featured"
                style="@style/TextAppearance.3Dify.SectionLabel"/>

            <TextView
                android:id="@+id/tv_see_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See all"
                android:textColor="@color/orange"
                android:textSize="@dimen/text_body_sm"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_featured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin"
            android:clipToPadding="false"
            android:orientation="horizontal"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

<?xml version="1.0" encoding="utf-8"?>
<!--
    REGISTER ACTIVITY
    ══════════════════
    WHY: New user account creation.
    FLOW: LoginActivity → RegisterActivity → LoginActivity (after success)
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_primary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- ── Back arrow ── -->
        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="@color/orange_neon"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ── Title ── -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Create Account."
            android:textColor="@color/white_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tv_back"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ── Subtitle ── -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Join 3Dify and start your journey"
            android:textColor="@color/gray_text"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ── Username field ── -->
        <EditText
            android:id="@+id/et_username"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:hint="Username"
            android:textColor="@color/white_secondary"
            android:textColorHint="@color/gray_muted"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPersonName"
            android:singleLine="true"
            android:imeOptions="actionNext"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Email field ── -->
        <EditText
            android:id="@+id/et_email"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:hint="Email address"
            android:textColor="@color/white_secondary"
            android:textColorHint="@color/gray_muted"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textEmailAddress"
            android:singleLine="true"
            android:imeOptions="actionNext"
            app:layout_constraintTop_toBottomOf="@id/et_username"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Password field ── -->
        <EditText
            android:id="@+id/et_password"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:hint="Password"
            android:textColor="@color/white_secondary"
            android:textColorHint="@color/gray_muted"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:imeOptions="actionNext"
            app:layout_constraintTop_toBottomOf="@id/et_email"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Confirm password ── -->
        <EditText
            android:id="@+id/et_confirm"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:hint="Confirm Password"
            android:textColor="@color/white_secondary"
            android:textColorHint="@color/gray_muted"
            android:textSize="13sp"
            android:background="@drawable/bg_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:singleLine="true"
            android:imeOptions="actionDone"
            app:layout_constraintTop_toBottomOf="@id/et_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Terms row ── -->
        <LinearLayout
            android:id="@+id/ll_terms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="top"
            app:layout_constraintTop_toBottomOf="@id/et_confirm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <CheckBox
                android:id="@+id/cb_terms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/orange_neon"/>

            <TextView
                android:id="@+id/tv_terms"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="I agree to the Terms of Service and Privacy Policy"
                android:textColor="@color/gray_text"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <!-- ── Create Account button ── -->
        <Button
            android:id="@+id/btn_create"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Create Account"
            android:textColor="@color/black_primary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/bg_btn_orange"
            app:layout_constraintTop_toBottomOf="@id/ll_terms"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Sign in link ── -->
        <TextView
            android:id="@+id/tv_signin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Already have one? Sign in"
            android:textColor="@color/gray_text"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/btn_create"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!--
    ONBOARDING PAGE FRAGMENT
    ══════════════════════════
    Reused for all 3 onboarding slides.
    Each page has: illustration card (top), title, subtitle.
    The OnboardingAdapter sets text/icon dynamically per page.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_primary"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <!-- ── Illustration Card ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_illustration"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_onboard_illus"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_onboard_title"
        app:layout_constraintHeight_percent="0.52">

        <!-- Center emoji / icon -->
        <TextView
            android:id="@+id/tv_onboard_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔷"
            android:textSize="52sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/ll_chips"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Orange accent underline below emoji -->
        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_orange"
            app:layout_constraintTop_toBottomOf="@id/tv_onboard_emoji"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 2x2 chip grid below accent line -->
        <LinearLayout
            android:id="@+id/ll_chips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tv_chip1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="📐 Model"
                    android:textColor="@color/gray_text"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="7dp"
                    android:background="@drawable/bg_onboard_chip"/>

                <TextView
                    android:id="@+id/tv_chip2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="🎨 Texture"
                    android:textColor="@color/gray_text"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="7dp"
                    android:background="@drawable/bg_onboard_chip"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_chip3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="💡 Light"
                    android:textColor="@color/gray_text"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="7dp"
                    android:background="@drawable/bg_onboard_chip"/>

                <TextView
                    android:id="@+id/tv_chip4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="🎬 Animate"
                    android:textColor="@color/gray_text"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="7dp"
                    android:background="@drawable/bg_onboard_chip"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── Page Title ── -->
    <TextView
        android:id="@+id/tv_onboard_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Master Blender 3D"
        android:textColor="@color/white_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/card_illustration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_onboard_sub"/>

    <!-- ── Page Subtitle ── -->
    <TextView
        android:id="@+id/tv_onboard_sub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Structured lessons from zero to professional 3D artist"
        android:textColor="@color/gray_text"
        android:textSize="12sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        app:layout_constraintTop_toBottomOf="@id/tv_onboard_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
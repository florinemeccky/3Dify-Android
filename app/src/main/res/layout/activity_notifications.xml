<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_margin"
        android:paddingEnd="@dimen/screen_margin"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:scaleType="fitCenter"
            android:background="@drawable/bg_surface_2"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Notifications"
            android:textColor="@color/text_1"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Section: Today -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_margin"
        android:layout_marginBottom="8dp"
        android:text="Today"
        style="@style/TextAppearance.3Dify.SectionLabel"/>

    <!-- Notification 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:paddingStart="@dimen/screen_margin"
        android:paddingEnd="@dimen/screen_margin"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_ripple_row"
        android:clickable="true"
        android:focusable="true">

        <!-- Icon container -->
        <LinearLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_achievement_unlocked"
            android:gravity="center"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="2dp">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_check" android:scaleType="fitCenter"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tutorial completed"
                android:textColor="@color/text_1"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You finished Sculpting Basics. Great work!"
                android:textColor="@color/text_3"
                android:textSize="@dimen/text_body_sm"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="2h ago"
            android:textColor="@color/text_3"
            android:textSize="@dimen/text_label"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border_subtle"
        android:layout_marginStart="@dimen/screen_margin"/>

    <!-- Notification 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:paddingStart="@dimen/screen_margin"
        android:paddingEnd="@dimen/screen_margin"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_ripple_row"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_surface_2"
            android:gravity="center"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="2dp">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_school" android:scaleType="fitCenter" android:alpha="0.6"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New course available"
                android:textColor="@color/text_1"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3 new Blender tutorials have been added to the library."
                android:textColor="@color/text_3"
                android:textSize="@dimen/text_body_sm"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="5h ago"
            android:textColor="@color/text_3"
            android:textSize="@dimen/text_label"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border_subtle"
        android:layout_marginStart="@dimen/screen_margin"/>

    <!-- Section: Yesterday -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_margin"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:text="Yesterday"
        style="@style/TextAppearance.3Dify.SectionLabel"/>

    <!-- Notification 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:paddingStart="@dimen/screen_margin"
        android:paddingEnd="@dimen/screen_margin"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_ripple_row"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@color/error_10"
            android:gravity="center"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="2dp">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_nav_progress" android:scaleType="fitCenter"
                app:tint="@color/error"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Keep your streak alive!"
                android:textColor="@color/text_1"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete a tutorial today to maintain your 7-day streak."
                android:textColor="@color/text_3"
                android:textSize="@dimen/text_body_sm"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="1d ago"
            android:textColor="@color/text_3"
            android:textSize="@dimen/text_label"/>
    </LinearLayout>

</LinearLayout>
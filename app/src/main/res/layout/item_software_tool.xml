<?xml version="1.0" encoding="utf-8"?>
<!--
    Single row in the 3D Tools section.
    Left: colored initial avatar
    Center: name + tagline
    Right: pricing badge + arrow
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="@drawable/bg_ripple_row"
    android:clickable="true"
    android:focusable="true">

    <!-- Colored initial avatar -->
    <LinearLayout
        android:id="@+id/ll_software_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_software_avatar"
        android:gravity="center"
        android:layout_marginEnd="16dp">

        <TextView
            android:id="@+id/tv_software_initial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B"
            android:textColor="#FF6A00"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Name and tagline -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_software_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Blender"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="3dp"/>

        <TextView
            android:id="@+id/tv_software_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Free and open source 3D suite"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Pricing badge -->
    <TextView
        android:id="@+id/tv_software_pricing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="Free"
        android:textColor="#34D399"
        android:textSize="10sp"
        android:textStyle="bold"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:background="@drawable/bg_badge_free"/>

    <!-- Arrow -->
    <ImageView
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:src="@drawable/ic_arrow_right"
        android:scaleType="fitCenter"
        android:alpha="0.3"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_profile.xml
    Required IDs:
      - tv_profile_username  (username from SQLite)
      - tv_user_email        (email from Firebase)
      - row_account          (navigates to AccountActivity)
      - row_settings         (navigates to SettingsActivity)
      - row_feedback         (navigates to UserFeedbackActivity)
      - row_reports          (navigates to ReportActivity)
      - row_help             (navigates to HelpActivity)
      - row_privacy          (navigates to PrivacyPolicyActivity)
      - btn_logout           (signs out)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Avatar and user info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="#1AFF6A00"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="34sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_profile_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Username"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_user_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="email@example.com"
                android:textColor="@color/text_muted"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Account row -->
        <LinearLayout
            android:id="@+id/row_account"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👤  My Account"
                android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#555555" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Settings row -->
        <LinearLayout
            android:id="@+id/row_settings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚙️  Settings"
                android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#555555" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Feedback row -->
        <LinearLayout
            android:id="@+id/row_feedback"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⭐  Give Feedback"
                android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#555555" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Reports row -->
        <LinearLayout
            android:id="@+id/row_reports"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📊  My Reports"
                android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#555555" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Help row -->
        <LinearLayout
            android:id="@+id/row_help"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="❓  Help &amp; Support"
                android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#555555" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Contact row -->
        <LinearLayout
            android:id="@+id/row_contact"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📞  Contact Us"
                android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#555555" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Complaints row -->
        <LinearLayout
            android:id="@+id/row_complaints"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚠️  Submit Complaint"
                android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#555555" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Privacy Policy row -->
        <LinearLayout
            android:id="@+id/row_privacy"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/background_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔒  Privacy Policy"
                android:textColor="@color/text_secondary" android:textSize="14sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="›" android:textColor="#555555" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Logout -->
        <LinearLayout
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#1AE74C3C"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚪  Logout"
                android:textColor="#E74C3C"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
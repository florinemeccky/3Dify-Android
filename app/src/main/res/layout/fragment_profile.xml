<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ══ PROFILE HEADER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:paddingStart="@dimen/screen_margin"
            android:paddingEnd="@dimen/screen_margin">

            <!-- Initials avatar -->
            <LinearLayout
                android:layout_width="@dimen/avatar_size"
                android:layout_height="@dimen/avatar_size"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_avatar_initials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="F"
                    android:textColor="@color/orange"
                    android:textSize="@dimen/avatar_initials_size"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Username -->
            <TextView
                android:id="@+id/tv_profile_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Florine"
                android:textColor="@color/text_1"
                android:textSize="@dimen/text_title"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <!-- Email -->
            <TextView
                android:id="@+id/tv_user_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="florine@email.com"
                android:textColor="@color/text_3"
                android:textSize="@dimen/text_body_sm"
                android:layout_marginBottom="20dp"/>

            <!-- Stat pills row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:background="@drawable/bg_stat_card"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:id="@+id/tv_profile_completed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/orange"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Done"
                        android:textColor="@color/text_3"
                        android:textSize="11sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:background="@drawable/bg_stat_card">

                    <TextView
                        android:id="@+id/tv_profile_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/error"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Streak"
                        android:textColor="@color/text_3"
                        android:textSize="11sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ══ DIVIDER ══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginBottom="8dp"/>

        <!-- ══ MENU ROWS ══ -->
        <!-- Each row is a flat item with a hairline separator beneath it -->

        <include layout="@layout/item_profile_row"
            android:id="@+id/row_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginStart="62dp"
            android:layout_marginEnd="0dp"/>

        <include layout="@layout/item_profile_row"
            android:id="@+id/row_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginStart="62dp"
            android:layout_marginEnd="0dp"/>

        <include layout="@layout/item_profile_row"
            android:id="@+id/row_feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginStart="62dp"
            android:layout_marginEnd="0dp"/>

        <include layout="@layout/item_profile_row"
            android:id="@+id/row_reports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginStart="62dp"
            android:layout_marginEnd="0dp"/>

        <include layout="@layout/item_profile_row"
            android:id="@+id/row_contact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginStart="62dp"
            android:layout_marginEnd="0dp"/>

        <include layout="@layout/item_profile_row"
            android:id="@+id/row_complaints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginStart="62dp"
            android:layout_marginEnd="0dp"/>

        <include layout="@layout/item_profile_row"
            android:id="@+id/row_help"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginStart="62dp"
            android:layout_marginEnd="0dp"/>

        <include layout="@layout/item_profile_row"
            android:id="@+id/row_privacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- ══ DIVIDER ══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="28dp"/>

        <!-- ══ LOGOUT ══ -->
        <LinearLayout
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginEnd="@dimen/screen_margin"
            android:background="@drawable/bg_btn_danger"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Out"
                android:textColor="@color/error"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
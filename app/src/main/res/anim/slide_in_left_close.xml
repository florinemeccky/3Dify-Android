<?xml version="1.0" encoding="utf-8"?>
<!--
    Back navigation ENTER — previous screen slides in from left.
    Starts at -40% to mirror the slide_out_left exit.
    Slightly faster than forward navigation so Back feels snappy.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <translate
        android:fromXDelta="-40%"
        android:toXDelta="0%"
        android:duration="220"
        android:interpolator="@android:interpolator/decelerate_cubic"/>
    <alpha
        android:fromAlpha="0.6"
        android:toAlpha="1.0"
        android:duration="220"/>
</set>